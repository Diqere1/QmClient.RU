{
  "required_files": [
    "AGENTS.md",
    "Claude.md",
    ".codestable/attention.md",
    ".codestable/reference/workflow-entry.md",
    ".codestable/reference/workflow-manifest.json",
    ".codestable/reference/agents-rules-maintenance.md",
    ".codestable/reference/pr-review-checklist.md",
    ".codestable/reference/pre-merge-verification.md",
    ".codestable/reference/log-classification.md",
    ".codestable/reference/release-notes-template.md",
    ".codestable/reference/event-summary-schema.md",
    "qmclient_scripts/check-gate.ps1",
    "qmclient_scripts/check-gate-workflow.md",
    "qmclient_scripts/check_workflow_docs.py",
    "qmclient_scripts/generate_release_notes.py",
    "qmclient_scripts/refresh_baseline_debt_allowlist.py",
    "qmclient_scripts/baseline_debt_allowlist.json",
    ".github/workflows/governance.yml"
  ],
  "managed_governance_directories": [
    {
      "base": ".codestable/reference",
      "glob": "*",
      "ignored_files": [
        ".codestable/reference/code-dimensions.md",
        ".codestable/reference/maintainer-notes.md",
        ".codestable/reference/requirement-example.md",
        ".codestable/reference/rmlui-backend-reference.md",
        ".codestable/reference/rmlui-core-reference.md",
        ".codestable/reference/rmlui-custom-elements-reference.md",
        ".codestable/reference/rmlui-data-binding-reference.md",
        ".codestable/reference/rmlui-debugger-reference.md",
        ".codestable/reference/rmlui-developer-guide.md",
        ".codestable/reference/rmlui-events-reference.md",
        ".codestable/reference/rmlui-file-interface-reference.md",
        ".codestable/reference/rmlui-font-engine-reference.md",
        ".codestable/reference/rmlui-gameclient-host-reference.md",
        ".codestable/reference/rmlui-monitoring-hud-reference.md",
        ".codestable/reference/rmlui-reference-index.md",
        ".codestable/reference/rmlui-render-helpers-reference.md",
        ".codestable/reference/rmlui-render-interface-reference.md",
        ".codestable/reference/rmlui-runtime-api-reference.md",
        ".codestable/reference/rmlui-settings-host-contract.md",
        ".codestable/reference/rmlui-system-input-reference.md",
        ".codestable/reference/rmlui-test-strategy.md",
        ".codestable/reference/rmlui-text-input-reference.md",
        ".codestable/reference/shared-conventions.md",
        ".codestable/reference/system-overview.md",
        ".codestable/reference/tools.md"
      ]
    },
    {
      "base": "qmclient_scripts",
      "glob": "*",
      "ignored_files": [
        "qmclient_scripts/check_config_variables.py",
        "qmclient_scripts/check_header_guards.py",
        "qmclient_scripts/cmake-windows.cmd",
        "qmclient_scripts/darwin_fix_install_names.py",
        "qmclient_scripts/diff_update.py",
        "qmclient_scripts/export_settings_commands_table.py",
        "qmclient_scripts/fix_style.py",
        "qmclient_scripts/make_lib_openssl.sh",
        "qmclient_scripts/strict-debug-check.ps1",
        "qmclient_scripts/tw_api.py",
        "qmclient_scripts/update.zsh"
      ]
    },
    {
      "base": ".github/workflows",
      "glob": "*",
      "ignored_files": [
        ".github/workflows/build.yml"
      ]
    }
  ],
  "agents_root_order": [
    "`AGENTS.md`",
    "`.codestable/attention.md`",
    "`.codestable/reference/workflow-entry.md`"
  ],
  "claude_sync_references": [
    "`AGENTS.md`",
    "`.codestable/reference/workflow-entry.md`",
    "`qmclient_scripts/check-gate.ps1`",
    "`.codestable/reference/pr-review-checklist.md`",
    "`.codestable/reference/pre-merge-verification.md`"
  ],
  "attention_required_references": [
    "`.codestable/reference/workflow-entry.md`"
  ],
  "agents_required_sections": [
    "## 文档入口（强制）",
    "## 仓库级检查入口",
    "## 审查与验证入口",
    "## RmlUI / CodeStable 约束"
  ],
  "workflow_entry_required_sections": [
    "### 1. 标准调试流程",
    "### 2. 日志分类",
    "### 3. 对照清单进行 PR 审查",
    "### 4. 迁移规划",
    "### 5. 发布说明撰写",
    "### 6. 遥测或事件摘要"
  ],
  "release_notes_required_references": [
    "`qmclient_scripts/generate_release_notes.py`",
    "`status`",
    "`--gate-report`"
  ],
  "workflow_routes": [
    {
      "name": "debug",
      "must_reference": [
        ".codestable/compound/2026-05-09-learning-windows-debug-symbol-workflow.md",
        ".codestable/compound/2026-05-10-decision-render-lifecycle-safety-constraints.md",
        "qmclient_scripts/strict-debug-check.ps1"
      ]
    },
    {
      "name": "logs",
      "must_reference": [
        ".codestable/reference/log-classification.md",
        "qmclient_scripts/check-gate.ps1",
        "qmclient_scripts/check-gate-workflow.md",
        "qmclient_scripts/refresh_baseline_debt_allowlist.py",
        "qmclient_scripts/baseline_debt_allowlist.json",
        ".github/workflows/governance.yml"
      ]
    },
    {
      "name": "pr_review",
      "must_reference": [
        ".codestable/reference/pr-review-checklist.md",
        ".codestable/reference/pre-merge-verification.md"
      ]
    },
    {
      "name": "release_notes",
      "must_reference": [
        ".codestable/reference/release-notes-template.md",
        "qmclient_scripts/generate_release_notes.py"
      ]
    },
    {
      "name": "event_summary",
      "must_reference": [
        ".codestable/reference/event-summary-schema.md",
        ".codestable/reference/log-classification.md"
      ]
    }
  ],
  "governance_workflow_required_snippets": [
    "quick-gate-windows:",
    "default-gate-windows:",
    "if: always()",
    "check-gate.ps1",
    "-Mode quick",
    "-Mode default",
    "-ExplainScope",
    "-ScopeReportPath",
    "refresh_baseline_debt_allowlist.py"
  ],
  "governance_workflow_required_jobs": [
    {
      "job_id": "workflow-docs",
      "required_steps": [
        {
          "name": "Check workflow documents",
          "must_contain": [
            "check_workflow_docs.py"
          ]
        },
        {
          "name": "Generate gate report fixture",
          "must_contain": [
            "check-gate.ps1",
            "-Mode quick",
            "-SkipPreflight",
            "-SkipConfigChecks",
            "-SkipHeaderChecks",
            "-SkipStyleCheck",
            "check-gate-fixture.json"
          ]
        },
        {
          "name": "Generate release notes smoke draft",
          "must_contain": [
            "generate_release_notes.py",
            "--gate-report",
            "check-gate-fixture.json",
            "release-notes-ci.md"
          ]
        },
        {
          "name": "Upload release notes smoke draft",
          "must_contain": [
            "tmp/release-notes-ci.md"
          ]
        }
      ]
    },
    {
      "job_id": "quick-gate-windows",
      "required_steps": [
        {
          "name": "Run quick governance gate",
          "must_contain": [
            "check-gate.ps1",
            "-Mode quick",
            "check-gate-ci.json",
            "check-gate-ci-scope.json",
            "-ExplainScope",
            "-ScopeReportPath",
            "Tee-Object"
          ]
        },
        {
          "name": "Refresh baseline allowlist dry-run",
          "must_contain": [
            "refresh_baseline_debt_allowlist.py",
            "--dry-run"
          ]
        },
        {
          "name": "Upload quick gate report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-ci.json"
          ]
        },
        {
          "name": "Upload quick gate log",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-ci.log"
          ]
        },
        {
          "name": "Upload quick gate scope report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-ci-scope.json"
          ]
        }
      ]
    },
    {
      "job_id": "default-gate-windows",
      "required_steps": [
        {
          "name": "Run default governance gate",
          "must_contain": [
            "check-gate.ps1",
            "-Mode default",
            "check-gate-default-ci.json",
            "check-gate-default-ci-scope.json",
            "-ExplainScope",
            "-ScopeReportPath",
            "Tee-Object"
          ]
        },
        {
          "name": "Upload default gate report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-default-ci.json"
          ]
        },
        {
          "name": "Upload default gate log",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-default-ci.log"
          ]
        },
        {
          "name": "Upload default gate scope report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-default-ci-scope.json"
          ]
        }
      ]
    }
  ]
}
