{
  "required_files": [
    "AGENTS.md",
    "CLAUDE.md",
    ".ai/harness.md",
    ".ai/session-lifecycle.md",
    ".ai/ddnet-development.md",
    ".ai/verification.md",
    ".ai/review.md",
    ".ai/reference.md",
    ".ai/workflow-manifest.json",
    "feature_list.json",
    "progress.md",
    "session-handoff.md",
    "init.sh",
    "qmclient_scripts/gate/baseline_debt_allowlist.json",
    "qmclient_scripts/gate/check-gate.sh",
    "qmclient_scripts/gate/check-gate-workflow.md",
    "qmclient_scripts/gate/check_workflow_docs.py",
    "qmclient_scripts/gate/sync_agents_claude.py",
    "qmclient_scripts/gate/strict-debug-check.sh",
    "qmclient_scripts/generate_release_notes.py",
    "qmclient_scripts/gate/refresh_baseline_debt_allowlist.py",
    ".github/workflows/governance.yml"
  ],
  "agents_root_order": [
    ".ai/harness.md",
    ".ai/session-lifecycle.md",
    ".ai/ddnet-development.md",
    ".ai/verification.md",
    ".ai/review.md",
    ".ai/reference.md"
  ],
  "agents_required_sections": [
    "## 入口原则",
    "## 启动顺序",
    "## 文档地图",
    "## 全局硬约束",
    "## 机械化入口"
  ],
  "agents_forbidden_snippets": [
    "## Build",
    "## Test",
    "## Source architecture",
    "## Release notes"
  ],
  "root_map_max_lines": 120,
  "claude_sync_references": [
    ".ai/harness.md",
    ".ai/reference.md"
  ],
  "claude_sync_mode": "sync_auto",
  "focused_ai_docs": [
    ".ai/harness.md",
    ".ai/session-lifecycle.md",
    ".ai/ddnet-development.md",
    ".ai/verification.md",
    ".ai/review.md",
    ".ai/reference.md"
  ],
  "reference_required_sections": [
    "## 任务路由",
    "## 提交前验证",
    "## PR 审查清单",
    "## 文档维护原则",
    "## 发布说明模板"
  ],
  "state_required_sections": {
    "progress.md": [
      "## Current State",
      "## Status",
      "## What's In Progress",
      "## Evidence"
    ],
    "session-handoff.md": [
      "## Current Objective",
      "## Verification Evidence",
      "## Blockers / Risks",
      "## Recommended Next Step"
    ]
  },
  "init_required_snippets": [
    "QmClient Harness Initialization",
    "check_workflow_docs.py",
    "RUN_QUICK_GATE",
    "RUN_BUILD",
    "RUN_CXX_TESTS",
    "RUN_RUST_TESTS"
  ],
  "feature_list_status_values": [
    "pending",
    "in-progress",
    "done",
    "blocked"
  ],
  "feature_list_max_in_progress": 1,
  "workflow_routes": [
    {
      "name": "harness",
      "must_reference": [
        ".ai/harness.md",
        ".ai/session-lifecycle.md"
      ]
    },
    {
      "name": "development",
      "must_reference": [
        ".ai/ddnet-development.md",
        ".ai/verification.md",
        ".ai/review.md"
      ]
    },
    {
      "name": "scripts",
      "must_reference": [
        "qmclient_scripts/gate/check-gate.sh",
        "qmclient_scripts/gate/check_workflow_docs.py",
        "qmclient_scripts/gate/strict-debug-check.sh",
        "qmclient_scripts/generate_release_notes.py"
      ]
    }
  ],
  "release_notes_required_references": [
    "发布说明模板"
  ],
  "managed_governance_directories": [
    {
      "base": ".ai",
      "glob": "*.md",
      "ignored_files": []
    },
    {
      "base": "qmclient_scripts/gate",
      "glob": "*",
      "ignored_files": [
        "qmclient_scripts/gate/check-gate.sh",
        "qmclient_scripts/gate/check-gate-workflow.md",
        "qmclient_scripts/gate/check_workflow_docs.py",
        "qmclient_scripts/gate/baseline_debt_allowlist.json",
        "qmclient_scripts/gate/refresh_baseline_debt_allowlist.py",
        "qmclient_scripts/gate/strict-debug-check.sh",
        "qmclient_scripts/gate/sync_agents_claude.py"
      ]
    },
    {
      "base": ".github/workflows",
      "glob": "*",
      "ignored_files": [
        ".github/workflows/build.yml"
      ]
    }
  ],
  "governance_workflow_required_snippets": [
    "workflow-docs:",
    "quick-gate:",
    "default-gate-windows:",
    "if: always()",
    "check-gate.sh",
    "--mode quick",
    "--mode default",
    "--explain-scope",
    "--scope-report-path",
    "refresh_baseline_debt_allowlist.py",
    "--gate-report"
  ],
  "governance_workflow_required_jobs": [
    {
      "job_id": "workflow-docs",
      "required_steps": [
        {
          "name": "Check workflow documents",
          "must_contain": [
            "check_workflow_docs.py"
          ]
        },
        {
          "name": "Generate gate report fixture",
          "must_contain": [
            "check-gate.sh",
            "--mode quick",
            "--skip-preflight",
            "--skip-config-checks",
            "--skip-header-checks",
            "--skip-style-check",
            "check-gate-fixture.json"
          ]
        },
        {
          "name": "Generate release notes smoke draft",
          "must_contain": [
            "generate_release_notes.py",
            "--gate-report",
            "check-gate-fixture.json",
            "release-notes-ci.md"
          ]
        },
        {
          "name": "Upload release notes smoke draft",
          "must_contain": [
            "tmp/release-notes-ci.md"
          ]
        }
      ]
    },
    {
      "job_id": "quick-gate",
      "required_steps": [
        {
          "name": "Run quick governance gate",
          "must_contain": [
            "check-gate.sh",
            "--mode quick",
            "--enable-clang-format-check",
            "check-gate-ci.json",
            "check-gate-ci-scope.json",
            "--explain-scope",
            "--scope-report-path",
            "tee"
          ]
        },
        {
          "name": "Refresh baseline allowlist dry-run",
          "must_contain": [
            "gate/refresh_baseline_debt_allowlist.py",
            "--dry-run"
          ]
        },
        {
          "name": "Upload quick gate report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-ci.json"
          ]
        },
        {
          "name": "Upload quick gate log",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-ci.log"
          ]
        },
        {
          "name": "Upload quick gate scope report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-ci-scope.json"
          ]
        }
      ]
    },
    {
      "job_id": "default-gate-windows",
      "required_steps": [
        {
          "name": "Run default governance gate",
          "must_contain": [
            "check-gate.sh",
            "--mode default",
            "check-gate-default-ci.json",
            "check-gate-default-ci-scope.json",
            "--explain-scope",
            "--scope-report-path",
            "tee"
          ]
        },
        {
          "name": "Upload default gate report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-default-ci.json"
          ]
        },
        {
          "name": "Upload default gate log",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-default-ci.log"
          ]
        },
        {
          "name": "Upload default gate scope report",
          "must_have_if": "always()",
          "must_contain": [
            "tmp/check-gate-default-ci-scope.json"
          ]
        }
      ]
    }
  ]
}
