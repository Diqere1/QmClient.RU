    ".ai/harness.md",
    ".ai/session-lifecycle.md",
    ".ai/ddnet-development.md",
    ".ai/verification.md",
    ".ai/review.md",
    ".ai/reference.md",
    ".ai/workflow-manifest.json",
    ".ai/feature_list.json",
    ".ai/progress.md",
    ".ai/session-handoff.md",
    "qmclient_scripts/init.sh",
    "qmclient_scripts/gate/baseline_debt_allowlist.json",
    "qmclient_scripts/gate/check_gate.py",
    "qmclient_scripts/gate/check_docs.py",
    "qmclient_scripts/gate/check-gate-workflow.md",
    "qmclient_scripts/gate/lib/__init__.py",
    "qmclient_scripts/gate/lib/report.py",
    "qmclient_scripts/gate/lib/runner.py",
    "qmclient_scripts/gate/lib/scope.py",
    "qmclient_scripts/gate/lib/agents_sync.py",
    "qmclient_scripts/gate/lib/docs_harness.py",
    "qmclient_scripts/generate_release_notes.py",
    "qmclient_scripts/脚本总览.md"
  ],
  "agents_root_order": [
    ".ai/harness.md",
    ".ai/session-lifecycle.md",
    ".ai/ddnet-development.md",
    ".ai/verification.md",
    ".ai/review.md",
    ".ai/reference.md"
  ],
  "agents_required_sections": [
    "## 入口原则",
    "## 启动顺序",
    "## 文档地图",
    "## 全局硬约束",
    "## 机械化入口"
  ],
  "agents_forbidden_snippets": [
    "## Build",
    "## Test",
    "## Source architecture",
    "## Release notes"
  ],
  "root_map_max_lines": 120,
  "claude_sync_references": [
    ".ai/harness.md",
    ".ai/reference.md"
  ],
  "claude_sync_mode": "sync_auto",
  "focused_ai_docs": [
    ".ai/harness.md",
    ".ai/session-lifecycle.md",
    ".ai/ddnet-development.md",
    ".ai/verification.md",
    ".ai/review.md",
    ".ai/reference.md"
  ],
  "reference_required_sections": [
    "## 任务路由",
    "## 提交前验证",
    "## PR 审查清单",
    "## 文档维护原则",
    "## 发布说明模板"
  ],
  "state_required_sections": {
    ".ai/progress.md": [
      "## Current State",
      "## Status",
      "## What's In Progress",
      "## Evidence"
    ],
    ".ai/session-handoff.md": [
      "## Current Objective",
      "## Verification Evidence",
      "## Blockers / Risks",
      "## Recommended Next Step"
    ]
  },
  "init_required_snippets": [
    "QmClient Harness Initialization",
    "check_docs.py",
    "RUN_QUICK_GATE",
    "RUN_BUILD",
    "RUN_CXX_TESTS",
    "RUN_RUST_TESTS"
  ],
  "feature_list_status_values": [
    "pending",
    "in-progress",
    "done",
    "blocked"
  ],
  "feature_list_max_in_progress": 1,
  "workflow_routes": [
    {
      "name": "harness",
      "must_reference": [
        ".ai/harness.md",
        ".ai/session-lifecycle.md"
      ]
    },
    {
      "name": "development",
      "must_reference": [
        ".ai/ddnet-development.md",
        ".ai/verification.md",
        ".ai/review.md"
      ]
    },
    {
      "name": "scripts",
      "must_reference": [
        "qmclient_scripts/gate/check_gate.py",
        "qmclient_scripts/gate/check_docs.py",
        "qmclient_scripts/generate_release_notes.py"
      ]
    }
  ],
  "release_notes_required_references": [
    "发布说明模板"
  ],
  "managed_governance_directories": [
    {
      "base": ".ai",
      "glob": "*.md",
      "ignored_files": []
    },
    {
      "base": "qmclient_scripts/gate",
      "glob": "*",
      "ignored_files": [
        "qmclient_scripts/gate/check-gate-workflow.md",
        "qmclient_scripts/gate/baseline_debt_allowlist.json",
        "qmclient_scripts/gate/check_docs.py",
        "qmclient_scripts/gate/check_gate.py"
      ]
    },
    {
      "base": "qmclient_scripts/gate/lib",
      "glob": "*.py",
      "ignored_files": []
    }
  ]
}
